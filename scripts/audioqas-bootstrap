#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"
OS_RELEASE_FILE="${AUDIOQAS_TEST_OS_RELEASE:-/etc/os-release}"

python_supported() {
  "$1" - <<'PY' >/dev/null 2>&1
import sys
raise SystemExit(0 if (3, 10) <= sys.version_info < (3, 13) else 1)
PY
}

find_installed_python() {
  for candidate in python3.12 python3.11 python3.10 python3; do
    if command -v "$candidate" >/dev/null 2>&1 && python_supported "$candidate"; then
      command -v "$candidate"
      return
    fi
  done
  return 1
}

os_release_value() {
  key="$1"
  [ -r "$OS_RELEASE_FILE" ] || return 1
  awk -F= -v key="$key" '$1 == key {gsub(/^"|"$/, "", $2); print $2; exit}' "$OS_RELEASE_FILE"
}

is_ubuntu_2204() {
  [ "$(os_release_value ID)" = "ubuntu" ] && [ "$(os_release_value VERSION_ID)" = "22.04" ]
}

require_ubuntu_2204_for_apt() {
  if is_ubuntu_2204; then
    return
  fi
  echo "[python] Failed. Reason: automatic apt install is only supported on Ubuntu 22.04." >&2
  echo "[python] Next: install Python 3.12 manually or run with PYTHON_BIN=/path/to/python3.12." >&2
  exit 1
}

install_python() {
  echo "[python] Python 3.10-3.12 not found. Automatic install is required." >&2
  if command -v brew >/dev/null 2>&1; then
    echo "[python] Purpose: install Python 3.12 for AudioQAS runtime and virtual environment creation." >&2
    brew install python@3.12 >&2
    return
  fi
  if command -v apt-get >/dev/null 2>&1; then
    require_ubuntu_2204_for_apt
    echo "[python] Purpose: install system Python and venv support for AudioQAS runtime." >&2
    sudo apt-get update >&2
    sudo apt-get install -y python3 python3-venv >&2
    return
  fi
  echo "[python] Failed. Reason: Python 3.10-3.12 is required, but no supported package manager was found." >&2
  echo "[python] Next: install Python 3.12 or run with PYTHON_BIN=/path/to/python3.12." >&2
  exit 1
}

find_python() {
  if [ -n "${PYTHON_BIN:-}" ]; then
    if python_supported "$PYTHON_BIN"; then
      printf '%s\n' "$PYTHON_BIN"
      return
    fi
    echo "[python] Failed. Reason: PYTHON_BIN=$PYTHON_BIN is outside supported Python 3.10-3.12 range." >&2
    exit 1
  fi
  if python_bin="$(find_installed_python)"; then
    printf '%s\n' "$python_bin"
    return
  fi
  install_python
  if python_bin="$(find_installed_python)"; then
    printf '%s\n' "$python_bin"
    return
  fi
  echo "[python] Failed. Reason: Python 3.10-3.12 is required but was not found after automatic install." >&2
  echo "[python] Next: install Python 3.12 or run with PYTHON_BIN=/path/to/python3.12." >&2
  exit 1
}

PYTHON_BIN="$(find_python)"

venv_supported() {
  [ -x ".venv/bin/python" ] && python_supported ".venv/bin/python"
}

if [ "${1:-}" = "--check-only" ] && [ ! -x ".venv/bin/python" ]; then
  "$PYTHON_BIN" -m audioqas.bootstrap "$@"
  exit $?
fi

if [ ! -x ".venv/bin/python" ]; then
  echo "[python] Purpose: create repo-local virtual environment for AudioQAS runtime."
  "$PYTHON_BIN" -m venv .venv
elif ! venv_supported; then
  echo "[python] Existing .venv uses unsupported Python; recreating in place."
  "$PYTHON_BIN" -m venv --clear .venv
fi

".venv/bin/python" -m audioqas.bootstrap "$@"
